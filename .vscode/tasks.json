{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build current file",
            "type": "cppbuild",
            "command": "/usr/bin/gcc",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-Werror",
                "-std=c11",
                "-lm",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.out"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run with input.txt",
            "type": "shell",
            "command": "./${fileBasenameNoExtension}.out < input.txt",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": ["Build current file"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Valgrind",
            "type": "shell",
            "command": "valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes ./${fileBasenameNoExtension}.out < input.txt",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": ["Build current file"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Test: Compare to Expected",
            "type": "shell",
            "command": "./${fileBasenameNoExtension}.out < input.txt > output.tmp && diff -u --color=always expected.txt output.tmp && echo '\n✅ TEST PASSED' || echo '\n❌ TEST FAILED'",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": ["Build current file"],
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}