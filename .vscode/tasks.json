{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build current file",
            "type": "cppbuild",
            "command": "/usr/bin/gcc",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-Werror",
                "-std=c11",
                "-lm",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.out"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run with input.txt",
            "type": "shell",
            "command": "./${fileBasenameNoExtension}.out < input.txt",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": [
                "Build current file"
            ],
            "problemMatcher": []
        }
    ]
}